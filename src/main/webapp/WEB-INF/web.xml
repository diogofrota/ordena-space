<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

    <display-name>ORDENA SPACE</display-name>

    <welcome-file-list>
        <welcome-file>login</welcome-file>
    </welcome-file-list>

    <session-config>
        <session-timeout>30</session-timeout>
        <tracking-mode>COOKIE</tracking-mode>
        <cookie-config>
            <name>ORDENA_SPACE_SESSION</name>
            <http-only>true</http-only>
        </cookie-config>
    </session-config>

    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>br.com.ordenaspace.filter.AuthFilter</filter-class>
    </filter>

    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <listener>
        <listener-class>br.com.ordenaspace.listener.GpsPollingContextListener</listener-class>
    </listener>

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>br.com.ordenaspace.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>br.com.ordenaspace.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DashboardServlet</servlet-name>
        <servlet-class>br.com.ordenaspace.servlet.DashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DashboardServlet</servlet-name>
        <url-pattern>/dashboard</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ViaturaServlet</servlet-name>
        <servlet-class>br.com.ordenaspace.servlet.ViaturaServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ViaturaServlet</servlet-name>
        <url-pattern>/viaturas</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>PolicialServlet</servlet-name>
        <servlet-class>br.com.ordenaspace.servlet.PolicialServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PolicialServlet</servlet-name>
        <url-pattern>/policiais</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SetorServlet</servlet-name>
        <servlet-class>br.com.ordenaspace.servlet.SetorServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SetorServlet</servlet-name>
        <url-pattern>/setores</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SetorMapaServlet</servlet-name>
        <servlet-class>br.com.ordenaspace.servlet.SetorMapaServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SetorMapaServlet</servlet-name>
        <url-pattern>/setores/mapa</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AtivacaoServlet</servlet-name>
        <servlet-class>br.com.ordenaspace.servlet.AtivacaoServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AtivacaoServlet</servlet-name>
        <url-pattern>/ativacao</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>MonitoramentoServlet</servlet-name>
        <servlet-class>br.com.ordenaspace.servlet.MonitoramentoServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MonitoramentoServlet</servlet-name>
        <url-pattern>/monitoramento</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ApiGpsServlet</servlet-name>
        <servlet-class>br.com.ordenaspace.servlet.ApiGpsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ApiGpsServlet</servlet-name>
        <url-pattern>/api/gps</url-pattern>
    </servlet-mapping>
</web-app>
